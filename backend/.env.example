# PostgreSQL 連線字串（Neon serverless 或任何 PostgreSQL）
# 格式：postgresql://user:password@host/dbname?sslmode=require
# 到 https://neon.tech/ 建立免費資料庫後取得
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT 簽名密鑰 — 用來簽發與驗證登入 token
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
# 未設定：後端自動產生臨時 key，每次重啟後所有用戶 token 失效（本地開發可接受）
JWT_SECRET=

# 管理員 API secret — 呼叫 /api/admin/* 時帶在 X-Admin-Secret header
# 可自訂任意字串，例如：solar-admin-2026-yourname
# 未設定：預設為 dev-admin-secret（本地開發可接受，部署前必須改掉）
ADMIN_SECRET=

# 允許的前端來源（CORS），逗號分隔
# 部署後填入 Vercel domain，例如：https://your-app.vercel.app,http://localhost:3000
# 未設定：允許所有來源（本地開發可不設）
CORS_ORIGINS=
