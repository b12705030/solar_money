# Mapbox token（地圖渲染 + 3D 建物）
# 到 https://account.mapbox.com/ 取得
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# Google Maps API key（地址自動完成 + 座標查詢）
# 需開啟 Places API（New）
# 到 https://console.cloud.google.com/ 取得
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Python 後端 URL（本地開發預設 8000）
NEXT_PUBLIC_API_URL=http://localhost:8000
